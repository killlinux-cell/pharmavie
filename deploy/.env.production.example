# Copier vers deploy/.env sur le VPS
# cp .env.production.example .env

# Domaines pharmavie.space
WEB_DOMAIN=pharmavie.space
API_DOMAIN=api.pharmavie.space

# URLs publiques
NEXT_PUBLIC_API_URL=https://api.pharmavie.space/api/v1
CORS_ORIGIN=https://pharmavie.space

# Secrets — générer sur le VPS : openssl rand -hex 32
JWT_SECRET=CHANGEZ_MOI_SECRET_LONG_ALEATOIRE
POSTGRES_PASSWORD=CHANGEZ_MOI_MOT_DE_PASSE_POSTGRES

JWT_EXPIRES_IN=7d
NODE_ENV=production

# Optionnel
OPENAI_API_KEY=
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
