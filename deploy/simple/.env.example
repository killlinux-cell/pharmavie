# Configuration déploiement simple — copier vers deploy/simple/.env
# cp .env.example .env && nano .env

# Obligatoire : email pour certificat HTTPS Let's Encrypt
CERTBOT_EMAIL=votre@email.com

# Domaines (ne changez que si vous utilisez un autre domaine)
WEB_DOMAIN=pharmavie.space
API_DOMAIN=api.pharmavie.space

# Secrets — laissez vide : le script les génère automatiquement au 1er lancement
POSTGRES_PASSWORD=
JWT_SECRET=

# Mode API : development affiche l'OTP dans les logs (pour tester)
# production pour mise en ligne réelle
NODE_ENV=development

# Optionnel
OPENAI_API_KEY=
CINETPAY_API_KEY=
CINETPAY_SITE_ID=

# SMS OTP — Twilio (voir CONFIGURATION_TWILIO.md)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# TWILIO_MESSAGING_SERVICE_SID=

# Alternative Africa's Talking
AFRICASTALKING_USERNAME=
AFRICASTALKING_API_KEY=
SMS_SENDER_ID=PharmaVie
